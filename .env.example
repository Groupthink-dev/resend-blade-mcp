# Resend API key (required) — get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Write operations (send, create, update, delete) — disabled by default
RESEND_WRITE_ENABLED=false

# Transport mode: stdio (default) or http
RESEND_MCP_TRANSPORT=stdio

# HTTP transport settings (only used when RESEND_MCP_TRANSPORT=http)
RESEND_MCP_HOST=127.0.0.1
RESEND_MCP_PORT=8770

# Bearer token for HTTP transport auth (optional, recommended for non-localhost)
RESEND_MCP_API_TOKEN=
